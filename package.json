{
    "name": "code-hp",
    "productName": "Code.HP",
    "version": "1.0.0",
    "description": "Code snippet manager with retro-futuristic alien UI",
    "main": "app/main/electron-main.js",
    "author": "lorik",
    "license": "MIT",
    "scripts": {
        "start": "electron .",
        "dev": "electronmon .",
        "build": "electron-builder",
        "build-win": "electron-builder --win",
        "build-mac": "electron-builder --mac",
        "build-linux": "electron-builder --linux",
        "build-all": "electron-builder --win --mac --linux",
        "dist": "npm run build"
    },
    "build": {
        "appId": "com.lorik.code-hp",
        "productName": "Code.HP",
        "directories": {
            "output": "dist"
        },
        "files": [
            "**/*",
            "!node_modules/**/*",
            "node_modules/monaco-editor/**/*"
        ],
        "extraResources": [
            {
                "from": "app/assets/fonts",
                "to": "fonts"
            }
        ],
        "win": {
            "signExecutable": false,
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64",
                        "ia32"
                    ]
                },
                {
                    "target": "portable",
                    "arch": [
                        "x64",
                        "ia32"
                    ]
                }
            ],
            "icon": "app/assets/icon.ico"
        },
        "mac": {
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ],
            "icon": "app/assets/icon.icns"
        },
        "linux": {
            "target": [
                {
                    "target": "AppImage",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "deb",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "app/assets/icon.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        }
    },
    "devDependencies": {
        "electron": "^43.0.0",
        "electron-builder": "^26.15.3",
        "electronmon": "^2.0.4"
    },
    "dependencies": {
        "monaco-editor": "^0.53.0"
    }
}
