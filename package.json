{
    "name": "code-hp",
    "productName": "Code.HP",
    "version": "1.0.7",
    "description": "Code snippet manager with retro-futuristic alien UI",
    "main": "app/main/electron-main.js",
    "author": "lorik",
    "license": "MIT",
    "scripts": {
        "start": "electron .",
        "dev": "electronmon .",
        "pack":"electron-builder --dir",
        "clean": "rimraf dist",
        "build": "electron-builder --win",
        "release":"npm run clean && electron-builder --win --publish always",
        "dist": "npm run release"
    },
    "build": {
        "appId": "com.lorik.code-hp",
        "productName": "Code.HP",
        "compression": "store",
        "publish": [
            {
                "provider": "github",
                "owner": "lorik440",
                "repo": "Code.HP"
            }
        ],
        "directories": {
            "output": "dist"
        },
        "files": [
           "**/*"
        ],
        "extraResources": [
            {
                "from": "app/assets/fonts",
                "to": "fonts"
            }
        ],
        "win": {
            "signExecutable": false,
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "app/assets/icon.ico"
        },

        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        }
    },
    "devDependencies": {
        "electron": "^43.0.0",
        "electron-builder": "^26.15.3",
        "electronmon": "^2.0.4",
        "rimraf": "^6.1.3"
    },
    "dependencies": {
        "electron-updater": "^6.8.9",
        "monaco-editor": "^0.53.0"
    }
}
